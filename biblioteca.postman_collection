                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.collectionVariables.set(\"id\", jsonData.id);\r",
                  "pm.collectionVariables.set(\"isbn\", jsonData.isbn);"
                ],
                "type": "text/javascript",
