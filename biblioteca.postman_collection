            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Función para generar un número aleatorio de N dígitos como string\r",
                  "const randomDigits = (n) => {\r",
                  "    let result = '';\r",
                  "    for (let i = 0; i < n; i++) {\r",
                  "        result += Math.floor(Math.random() * 10);\r",
                  "    }\r",
                  "    return result;\r",
                  "};\r",
                  "\r",
                  "// Construir el ISBN con el formato 978-X-XX-XXXXXX-X\r",
                  "const prefix = \"978\";\r",
                  "const group = randomDigits(1);      // 1 dígito\r",
                  "const publisher = randomDigits(2);  // 2 dígitos\r",
                  "const title = randomDigits(6);      // 6 dígitos\r",
                  "const checkDigit = randomDigits(1); // 1 dígito (último)\r",
                  "\r",
                  "const isbn = `${prefix}-${group}-${publisher}-${title}-${checkDigit}`;\r",
                  "\r",
                  "pm.collectionVariables.set(\"isbn\", isbn);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
